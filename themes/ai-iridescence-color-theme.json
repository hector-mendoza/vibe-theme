	"tokenColors": [
		{
			"name": "Comment",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": { "fontStyle": "italic", "foreground": "#2d2d45" }
		},
		{
			"name": "Variables",
			"scope": ["variable", "string constant.other.placeholder"],
			"settings": { "foreground": "#E2E8F0" }
		},
		{
			"name": "Invalid",
			"scope": ["invalid", "invalid.illegal"],
			"settings": { "foreground": "#F87171" }
		},
		{
			"name": "Keyword, Storage",
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": { "foreground": "#e879f9" }
		},
		{
			"name": "Operator, Misc",
			"scope": [
				"keyword.control", "constant.other.color", "punctuation",
				"meta.tag", "punctuation.definition.tag",
				"punctuation.definition.tag.html",
				"punctuation.definition.tag.begin.html",
				"punctuation.definition.tag.end.html",
				"punctuation.section.embedded",
				"keyword.other.template", "keyword.other.substitution"
			],
			"settings": { "foreground": "#818cf8" }
		},
		{
			"name": "Tag",
			"scope": ["entity.name.tag", "meta.tag.sgml", "markup.deleted.git_gutter"],
			"settings": { "foreground": "#f0abfc" }
		},
		{
			"name": "Function, Special Method",
			"scope": [
				"entity.name.function", "meta.function-call",
				"variable.function", "support.function",
				"keyword.other.special-method"
			],
			"settings": { "foreground": "#818cf8" }
		},
		{
			"name": "Block Level Variables",
			"scope": ["meta.block variable.other"],
			"settings": { "foreground": "#f0abfc" }
		},
		{
			"name": "Number, Constant, Tag Attribute, Embedded",
			"scope": [
				"constant.numeric", "constant.language", "support.constant",
				"constant.character", "constant.escape", "variable.parameter",
				"keyword.other.unit", "keyword.other"
			],
			"settings": { "foreground": "#fde68a" }
		},
		{
			"name": "String, Symbols, Inherited Class, Markup Heading",
			"scope": [
				"string", "constant.other.symbol", "constant.other.key",
				"entity.other.inherited-class", "markup.heading",
				"markup.inserted.git_gutter",
				"meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
			],
			"settings": { "foreground": "#34d399" }
		},
		{
			"name": "Class, Support",
			"scope": [
				"entity.name", "support.type", "support.class",
				"support.other.namespace.use.php", "meta.use.php",
				"support.other.namespace.php", "markup.changed.git_gutter",
				"support.type.sys-types"
			],
			"settings": { "foreground": "#fde68a" }
		},
		{
			"name": "Entity Types",
			"scope": ["support.type"],
			"settings": { "foreground": "#a5b4fc" }
		},
		{
			"name": "CSS Class and Support",
			"scope": [
				"source.css support.type.property-name",
				"source.sass support.type.property-name",
				"source.scss support.type.property-name",
				"source.less support.type.property-name",
				"source.stylus support.type.property-name",
				"source.postcss support.type.property-name"
			],
			"settings": { "foreground": "#a5b4fc" }
		},
		{
			"name": "Attributes",
			"scope": ["entity.other.attribute-name"],
			"settings": { "foreground": "#e879f9" }
		},
		{
			"name": "HTML Attributes",
			"scope": [
				"text.html.basic entity.other.attribute-name.html",
				"text.html.basic entity.other.attribute-name"
			],
			"settings": { "fontStyle": "italic", "foreground": "#fde68a" }
		},
		{
			"name": "CSS Classes",
			"scope": ["entity.other.attribute-name.class"],
			"settings": { "foreground": "#fde68a" }
		},
		{
			"name": "Inserted",
			"scope": ["markup.inserted"],
			"settings": { "foreground": "#34d399" }
		},
		{
			"name": "Deleted",
			"scope": ["markup.deleted"],
			"settings": { "foreground": "#F87171" }
		},
		{
			"name": "Changed",
			"scope": ["markup.changed"],
			"settings": { "foreground": "#e879f9" }
		},
		{
			"name": "Regular Expressions",
			"scope": ["string.regexp"],
			"settings": { "foreground": "#818cf8" }
		},
		{
			"name": "Escape Characters",
			"scope": ["constant.character.escape"],
			"settings": { "foreground": "#818cf8" }
		},
		{
			"name": "URL",
			"scope": ["*url*", "*link*", "*uri*"],
			"settings": { "fontStyle": "underline" }
		},
		{
			"name": "Decorators",
			"scope": ["tag.decorator.js entity.name.tag.js", "tag.decorator.js punctuation.definition.tag.js"],
			"settings": { "fontStyle": "italic", "foreground": "#818cf8" }
		},
		{
			"name": "JSON Key - Level 0",
			"scope": ["source.json meta.structure.dictionary.json support.type.property-name.json"],
			"settings": { "foreground": "#e879f9" }
		},
		{
			"name": "JSON Key - Level 1",
			"scope": ["source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"],
			"settings": { "foreground": "#818cf8" }
		},
		{
			"name": "JSON Key - Level 2",
			"scope": ["source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"],
			"settings": { "foreground": "#34d399" }
		},
		{
			"name": "Markdown - Heading",
			"scope": ["markdown.heading", "markup.heading | markup.heading entity.name", "markup.heading.markdown punctuation.definition.heading.markdown"],
			"settings": { "foreground": "#e879f9" }
		},
		{
			"name": "Markup - Bold",
			"scope": ["markup.bold", "markup.bold string"],
			"settings": { "fontStyle": "bold", "foreground": "#f0abfc" }
		},
		{
			"name": "Markup - Italic",
			"scope": ["markup.italic"],
			"settings": { "fontStyle": "italic", "foreground": "#f0abfc" }
		},
		{
			"name": "Markdown - Link",
			"scope": ["string.other.link.title.markdown"],
			"settings": { "foreground": "#818cf8" }
		}
	]
}
